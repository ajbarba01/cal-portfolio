# Supabase — copy to .env.local and fill from your project's API keys page
# https://supabase.com/dashboard/project/_/settings/api-keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secret key (sb_secret_...). Elevated access; bypasses RLS. Never expose to the client.
SUPABASE_SECRET_KEY=

# Stripe — local TEST mode (sandbox). Live keys NEVER go in any env file.
# 1. From the Stripe dashboard in TEST mode (Developers > API keys), copy the
#    publishable (pk_test_...) + secret (sk_test_...) keys into .env.local.
# 2. Forward webhooks locally (needs the Stripe CLI):
#      stripe listen --forward-to localhost:3000/api/webhooks/stripe
#    Copy the printed whsec_... into STRIPE_WEBHOOK_SECRET (in .env.local).
# 3. Pay with test card 4242 4242 4242 4242, any future expiry, any CVC/ZIP.
# The integration suite uses a fake gateway via .env.test — no real key for `npm test`.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend — email notifications
RESEND_API_KEY=
EMAIL_FROM=

# Cron — secret shared with Vercel to auth-gate /api/cron/* routes
CRON_SECRET=
